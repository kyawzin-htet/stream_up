generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

enum MembershipType {
  FREE
  PREMIUM
}

enum MembershipUpgradeStatus {
  PENDING
  APPROVED
  REJECTED
}

model User {
  id                   String           @id @default(uuid())
  email                String           @unique
  passwordHash         String
  telegramUserId       String?          @unique
  membershipType       MembershipType   @default(FREE)
  membershipExpiresAt  DateTime?
  membershipExpiryNoticeAt DateTime?
  membershipExpiredNoticeAt DateTime?
  createdAt            DateTime         @default(now())

  telegramLinkTokens   TelegramLinkToken[]
  videos               Video[]          @relation("UserUploads")
  deletedVideos        Video[]          @relation("VideoDeletedBy")
  comments             Comment[]
  upgradeRequests      MembershipUpgradeRequest[]
  reviewedUpgrades     MembershipUpgradeRequest[] @relation("ReviewedBy")
}

model Video {
  id                 String   @id @default(uuid())
  title              String
  description        String
  keywords           String[] @default([])
  telegramFileId     String
  telegramMessageId  String
  telegramChannelId  String
  isPremium          Boolean  @default(false)
  createdAt          DateTime @default(now())
  deletedAt          DateTime?

  categoryId         String
  category           Category @relation(fields: [categoryId], references: [id])

  uploaderId         String?
  uploader           User?    @relation("UserUploads", fields: [uploaderId], references: [id])
  deletedById        String?
  deletedBy          User?    @relation("VideoDeletedBy", fields: [deletedById], references: [id])
  comments           Comment[]

  @@index([title])
  @@index([categoryId])
  @@index([deletedAt])
}

model Comment {
  id        String   @id @default(uuid())
  body      String
  createdAt DateTime @default(now())

  videoId   String
  video     Video    @relation(fields: [videoId], references: [id])

  userId    String
  user      User     @relation(fields: [userId], references: [id])

  parentId  String?
  parent    Comment? @relation("CommentReplies", fields: [parentId], references: [id])
  replies   Comment[] @relation("CommentReplies")

  @@index([videoId])
  @@index([parentId])
  @@index([createdAt])
}

model Category {
  id        String   @id @default(uuid())
  name      String
  slug      String   @unique
  createdAt DateTime @default(now())
  videos    Video[]
}

model PricingSettings {
  id        Int      @id @default(1)
  currency  String   @default("USD")
  updatedAt DateTime @updatedAt
}

model PricingPlan {
  id             String   @id @default(uuid())
  code           String   @unique
  name           String
  durationMonths Int?
  amount         Decimal  @db.Decimal(10, 2)
  active         Boolean  @default(true)
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt

  upgradeRequests MembershipUpgradeRequest[]
}

model MembershipUpgradeRequest {
  id                        String                  @id @default(uuid())
  userId                    String
  user                      User                    @relation(fields: [userId], references: [id])
  planId                    String
  plan                      PricingPlan             @relation(fields: [planId], references: [id])
  status                    MembershipUpgradeStatus @default(PENDING)
  note                      String?
  amountSnapshot            Decimal                 @db.Decimal(10, 2)
  currencySnapshot          String
  planNameSnapshot          String
  durationMonthsSnapshot    Int?
  paymentSlipFileId         String
  paymentSlipMessageId      String
  paymentSlipChannelId      String
  reviewedById              String?
  reviewedBy                User?                   @relation("ReviewedBy", fields: [reviewedById], references: [id])
  reviewedAt                DateTime?
  createdAt                 DateTime                @default(now())

  @@index([status])
  @@index([userId])
  @@index([planId])
}

model TelegramLinkToken {
  id         String   @id @default(uuid())
  token      String   @unique
  userId     String
  user       User     @relation(fields: [userId], references: [id])
  expiresAt  DateTime
  usedAt     DateTime?
  createdAt  DateTime @default(now())

  @@index([token])
}
